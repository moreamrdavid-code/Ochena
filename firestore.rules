rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "ridoymostofa.1@gmail.com" && request.auth.token.email_verified == true);
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isChatParticipant(chatData) {
      return isAuthenticated() && request.auth.uid in chatData.users;
    }

    function isGuest(userId) {
      return userId.matches("^guest_.*");
    }

    function isParticipant(userId, chatData) {
      return userId in chatData.users;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /chats/{chatId} {
      // Allow read/update if user is in the 'users' array (works for both Auth and Guests)
      allow read, update: if isAdmin() || (chatId.size() > 0); 
      allow create: if true;
    }

    match /queue/{userId} {
      allow read, write: if true; // Allow guests to join and leave queue
    }

    match /online_users/{userId} {
      allow read, write: if true; // Allow guests to show online status
    }

    match /stats/global {
      allow read: if true;
      allow write: if isAuthenticated();
    }
  }
}
