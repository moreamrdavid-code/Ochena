rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "ridoymostofa.1@gmail.com" && request.auth.token.email_verified == true);
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isChatParticipant(chatData) {
      return isAuthenticated() && request.auth.uid in chatData.users;
    }

    function isGuest(userId) {
      return userId.matches("^guest_.*");
    }

    function isParticipant(userId, chatData) {
      return userId in chatData.users;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /chats/{chatId} {
      allow read: if isAdmin() || (request.auth != null && request.auth.uid in resource.data.users) || (resource.data.users.hasAny([request.resource.data.uid]) || resource.data.users.hasAny([resource.data.users[0]])); // Simplified for guests
      allow read: if isAdmin() || (request.auth != null && request.auth.uid in resource.data.users) || (resource.data != null && resource.data.users.hasAny([request.headers.uid])); // This is tricky for guests
      
      // Better way for guests:
      allow read, update: if isAdmin() || (request.auth != null && request.auth.uid in resource.data.users) || (chatId.size() > 0); 
      allow create: if true;
    }

    match /queue/{userId} {
      allow read, write: if isAdmin() || request.auth.uid == userId || userId.matches("^guest_.*");
      allow list: if true;
    }

    match /online_users/{userId} {
      allow read: if true;
      allow write: if isAdmin() || request.auth.uid == userId || userId.matches("^guest_.*");
    }

    match /stats/global {
      allow read: if true;
      allow write: if isAuthenticated();
    }
  }
}
